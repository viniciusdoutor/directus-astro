---
import goldieSimulado from "../assets/goldie/goldie_simulado.webp";
import estudanteDedicado from "../assets/conquistas/Estudante Dedicado.png";
import jurista from "../assets/conquistas/Jurista.png";
import mestreLeis from "../assets/conquistas/Mestre das Leis.png";
---

<div
  class="my-10 rounded-2xl overflow-hidden"
  style="background: linear-gradient(135deg, #0f2340 0%, #1a3a6b 60%, #0f2340 100%); border: 1px solid rgba(200,150,12,0.25)"
>
  <div class="flex flex-col sm:flex-row items-center gap-0 sm:gap-4">

    <!-- Goldie simulado -->
    <div class="flex-shrink-0 w-40 sm:w-44 self-end sm:self-auto pt-6 sm:pt-0 sm:pl-6">
      <img
        src={goldieSimulado.src}
        alt="Goldie no simulado"
        class="w-full object-contain drop-shadow-xl"
        style="max-height: 200px;"
        loading="lazy"
      />
    </div>

    <!-- Conteúdo -->
    <div class="flex-1 p-6 sm:py-8 sm:pr-8 sm:pl-2 text-center sm:text-left">
      <p class="text-[10px] font-sans font-bold uppercase tracking-widest mb-2" style="color: #c8960c">
        Pratique com o Goldie
      </p>
      <h3 class="font-display font-bold text-white text-xl leading-snug mb-2">
        Transforme leitura em aprovação
      </h3>
      <p class="text-white/55 text-sm font-sans leading-relaxed mb-5 max-w-xs mx-auto sm:mx-0">
        Faça simulados personalizados sobre os temas que você acabou de estudar. O Goldie adapta as questões ao seu nível.
      </p>

      <!-- Badges -->
      <div class="flex items-center justify-center sm:justify-start gap-4 mb-5">
        <div class="flex flex-col items-center gap-1">
          <img src={estudanteDedicado.src} alt="Estudante Dedicado" class="w-9 h-9 object-contain" loading="lazy" />
          <span class="text-[9px] font-sans text-white/35 leading-tight text-center max-w-[52px]">Estudante Dedicado</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src={jurista.src} alt="Jurista" class="w-9 h-9 object-contain" loading="lazy" />
          <span class="text-[9px] font-sans text-white/35 leading-tight text-center max-w-[52px]">Jurista</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src={mestreLeis.src} alt="Mestre das Leis" class="w-9 h-9 object-contain" loading="lazy" />
          <span class="text-[9px] font-sans text-white/35 leading-tight text-center max-w-[52px]">Mestre das Leis</span>
        </div>
        <p class="text-white/25 text-[11px] font-sans hidden md:block pl-1">Desbloqueie conquistas praticando</p>
      </div>

      <a
        href="#"
        class="inline-flex items-center gap-2 px-6 py-2.5 text-navy text-sm font-sans font-bold rounded-xl transition-colors"
        style="background: #c8960c"
        onmouseover="this.style.background='#b07d0a'"
        onmouseout="this.style.background='#c8960c'"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        Iniciar simulado com o Goldie
      </a>
    </div>
  </div>
</div>
