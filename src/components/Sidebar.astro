---
import type { Category, Tag } from "../lib/directus";

interface Props {
  categories: Category[];
  tags: Tag[];
  activeCategorySlug?: string;
  activeTagSlug?: string;
}
const { categories, tags, activeCategorySlug, activeTagSlug } = Astro.props;
---

<aside class="space-y-6">

  <!-- Categorias -->
  <div class="bg-white rounded-lg border border-border overflow-hidden">
    <div class="px-5 py-3 border-b border-border bg-paper">
      <h2 class="font-display font-bold text-base text-ink">Categorias</h2>
    </div>
    <ul class="p-2 space-y-0.5">
      {categories.map(cat => (
        <li>
          <a
            href={`/categoria/${cat.slug}`}
            class={`flex items-center gap-2.5 px-3 py-2 rounded text-sm font-sans no-underline transition-colors
              ${activeCategorySlug === cat.slug
                ? "bg-navy text-white font-semibold"
                : "text-ink hover:bg-paper"}`}
          >
            <span
              class="w-2 h-2 rounded-full flex-shrink-0"
              style={`background: ${cat.color ?? "#0f2340"}`}
            ></span>
            {cat.name}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Tags -->
  <div class="bg-white rounded-lg border border-border overflow-hidden">
    <div class="px-5 py-3 border-b border-border bg-paper">
      <h2 class="font-display font-bold text-base text-ink">Tags</h2>
    </div>
    <div class="p-4 flex flex-wrap gap-2">
      {tags.map(tag => (
        <a
          href={`/tag/${tag.slug}`}
          class={`text-xs font-sans font-medium px-3 py-1.5 rounded-full border no-underline transition-colors
            ${activeTagSlug === tag.slug
              ? "bg-navy text-white border-navy"
              : "text-muted border-border hover:border-gold hover:text-gold"}`}
        >
          {tag.name}
        </a>
      ))}
    </div>
  </div>

  <!-- Sobre -->
  <div class="rounded-lg overflow-hidden" style="background: #0f2340">
    <div class="px-5 py-3 border-b border-white/10">
      <h2 class="font-display font-bold text-base text-white">Sobre o Portal</h2>
    </div>
    <div class="p-5">
      <p class="text-white/60 text-sm leading-relaxed">
        O <strong class="text-white">Portal Golden Jus</strong> é o portal de referência em notícias de concursos jurídicos.
        Cobrimos editais, resultados e dicas para quem busca ingressar nas carreiras do Direito.
      </p>
    </div>
  </div>

</aside>
