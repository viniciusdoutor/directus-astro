---
import CategoryBadge from "./CategoryBadge.astro";
import TagPill from "./TagPill.astro";
import CoverImage from "./CoverImage.astro";
import { formatDate, assetUrl, categoryIcon } from "../lib/utils";
import type { PostSummary } from "../lib/directus";

interface Props {
  post: PostSummary;
  directusUrl: string;
}

const { post, directusUrl } = Astro.props;
const category = post.category;
const tags = post.tags.map(pt => pt.tags_id);
const imgSrc = assetUrl(post.image, directusUrl, "width=600&height=340&fit=cover&quality=80");
const icon = categoryIcon(category?.slug ?? "");
---

<article class="group bg-white rounded-lg overflow-hidden border border-border shadow-sm hover:shadow-md transition-all duration-200 flex flex-col h-full">

  <!-- Capa -->
  <a href={`/blog/${post.slug}`} class="block overflow-hidden flex-shrink-0 h-44">
    {imgSrc ? (
      <img
        src={imgSrc}
        alt={post.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    ) : (
      <CoverImage
        title={post.title}
        slug={post.slug}
        categoryName={category?.name}
        categoryColor={category?.color ?? "#0f2340"}
        icon={icon}
        showTitle={true}
        class="w-full h-full group-hover:scale-105 transition-transform duration-300"
      />
    )}
  </a>

  <div class="p-5 flex flex-col flex-1 gap-2.5">

    {category && (
      <div>
        <CategoryBadge name={category.name} slug={category.slug} color={category.color} size="sm" />
      </div>
    )}

    <a href={`/blog/${post.slug}`} class="block no-underline">
      <h2 class="font-display font-bold text-lg text-ink leading-snug hover:text-navy-light transition-colors line-clamp-3">
        {post.title}
      </h2>
    </a>

    {post.excerpt && (
      <p class="text-muted text-sm leading-relaxed line-clamp-2">{post.excerpt}</p>
    )}

    <div class="mt-auto pt-3 border-t border-border space-y-2">
      <div class="flex items-center gap-2 text-xs text-muted font-sans">
        <span>{formatDate(post.published_date)}</span>
        {post.reading_time && (
          <>
            <span class="text-border">·</span>
            <span>{post.reading_time} min</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, 3).map(tag => <TagPill name={tag.name} slug={tag.slug} />)}
        </div>
      )}
    </div>

  </div>
</article>
