---
import Layout from "../layouts/Layout.astro";
import { fetchFeaturedPost, fetchPosts, fetchCategories, fetchGlobal } from "../lib/queries";
import { formatDate, assetUrl, categoryIcon } from "../lib/utils";
import CoverImage from "../components/CoverImage.astro";
import cargo1 from "../assets/cargos/1.png";
import cargo2 from "../assets/cargos/2.png";
import cargo3 from "../assets/cargos/3.png";
import cargo4 from "../assets/cargos/4.png";
import cargo5 from "../assets/cargos/5.png";
import cargo6 from "../assets/cargos/6.png";
import cargo7 from "../assets/cargos/7.png";
import concurseiroPersistente from "../assets/conquistas/Concurseiro Persistente.png";
import membroPreparado       from "../assets/conquistas/Membro Preparado.png";
import estudanteDedicado     from "../assets/conquistas/Estudante Dedicado.png";
import medalha100            from "../assets/conquistas/Medalha 100.png";
import jurista               from "../assets/conquistas/Jurista.png";
import mestreLeis            from "../assets/conquistas/Mestre das Leis.png";
import revisorExpert         from "../assets/conquistas/Revisor Expert.png";

const AREA_ICONS: Record<string, string> = {
  "concursos-abertos":   concurseiroPersistente.src,
  "concursos-estaduais": membroPreparado.src,
  "cognicao-aprendizado": estudanteDedicado.src,
  "editais-resultados":  medalha100.src,
  "jurisprudencia":      jurista.src,
  "legislacao":          mestreLeis.src,
  "stf-tribunais":       revisorExpert.src,
};
const getAreaIcon = (slug: string) => AREA_ICONS[slug] ?? concurseiroPersistente.src;

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL;

const [global, featured, recent, categories] = await Promise.all([
  fetchGlobal(),
  fetchFeaturedPost(),
  fetchPosts({ limit: 8 }),
  fetchCategories(),
]);

const hero = featured ?? recent[0] ?? null;
const heroCategory = hero?.category ?? null;
const heroImgSrc = hero ? assetUrl(hero.image, directusUrl, "width=1400&height=700&fit=cover&quality=85") : null;

const restPosts = recent.filter(p => p.id !== hero?.id);
const latestNews = restPosts.slice(0, 3);
const highlights  = restPosts.slice(3, 6);
---

<Layout title={global.title} description={global.description ?? undefined}>

  <!-- Em Alta -->
  {hero && (
    <div class="bg-white border-b border-border">
      <div class="max-w-7xl mx-auto px-6 py-2.5 flex items-center gap-3">
        <span class="bg-gold text-white text-[10px] font-sans font-bold uppercase tracking-widest px-2.5 py-1 rounded flex-shrink-0">
          Em Alta
        </span>
        <p class="text-ink/70 text-sm font-sans truncate flex-1">{hero.title}</p>
        <a href="/blog" class="text-gold text-sm font-sans font-medium hover:text-navy transition-colors flex-shrink-0 hidden sm:flex items-center gap-1">
          Ver todas as notícias <span>›</span>
        </a>
      </div>
    </div>
  )}

  <!-- Hero + Últimas Notícias -->
  <section class="max-w-7xl mx-auto px-6 pt-7 pb-6">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-6 items-stretch">

      {hero && (
        <a href={`/blog/${hero.slug}`} class="group block relative rounded-xl overflow-hidden no-underline shadow-md">
          <div class="relative h-[420px] md:h-[490px]">
            {heroImgSrc ? (
              <img src={heroImgSrc} alt={hero.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            ) : (
              <CoverImage
                title={hero.title}
                slug={hero.slug}
                categoryName={heroCategory?.name}
                categoryColor={heroCategory?.color ?? "#0f2340"}
                icon={categoryIcon(heroCategory?.slug ?? "")}
                showTitle={false}
                class="w-full h-full"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-7">
            <div class="flex items-center gap-3 mb-3">
              <span class="bg-gold text-white text-[10px] font-sans font-bold uppercase tracking-widest px-2.5 py-1 rounded-sm">Destaque</span>
              {heroCategory && (
                <span class="text-white/70 text-xs font-sans uppercase tracking-wider">{heroCategory.name}</span>
              )}
            </div>
            <h1 class="font-display font-bold text-white text-2xl md:text-[2rem] leading-tight max-w-2xl mb-3 group-hover:text-gold-light transition-colors">
              {hero.title}
            </h1>
            {hero.excerpt && (
              <p class="text-white/60 text-sm md:text-base max-w-xl line-clamp-2 mb-4 font-serif">{hero.excerpt}</p>
            )}
            <div class="flex items-center gap-3 text-white/45 text-sm font-sans">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{formatDate(hero.published_date)}</span>
              {hero.reading_time && (
                <>
                  <span>·</span>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span>{hero.reading_time} min de leitura</span>
                </>
              )}
            </div>
          </div>
        </a>
      )}

      <!-- Últimas Notícias sidebar -->
      <div class="bg-white border border-border rounded-xl shadow-sm flex flex-col h-full">
        <div class="px-5 pt-5 pb-4 border-b border-border flex-shrink-0">
          <h2 class="font-display font-bold text-xl text-ink">Últimas Notícias</h2>
          <div class="h-0.5 w-10 bg-gold mt-1.5"></div>
        </div>
        <div class="flex flex-col divide-y divide-border flex-1">
          {latestNews.map((post) => {
            const cat = post.category;
            const thumb = assetUrl(post.image, directusUrl, "width=200&height=140&fit=cover&quality=75");
            return (
              <a href={`/blog/${post.slug}`} class="group flex gap-3 no-underline px-5 py-4 hover:bg-gray-50 transition-colors flex-1">
                {thumb ? (
                  <img src={thumb} alt={post.title} class="w-[84px] h-[68px] object-cover rounded-md flex-shrink-0 self-start" loading="lazy" />
                ) : (
                  <div class="w-[84px] h-[68px] rounded-md flex-shrink-0 self-start overflow-hidden">
                    <CoverImage
                      title={post.title}
                      slug={post.slug}
                      categoryName={cat?.name}
                      categoryColor={cat?.color ?? "#0f2340"}
                      icon={categoryIcon(cat?.slug ?? "")}
                      showTitle={false}
                      class="w-full h-full"
                    />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  {cat && (
                    <span class="text-[10px] font-sans font-bold uppercase tracking-wider block mb-1" style={`color: ${cat.color ?? "#1d4ed8"}`}>
                      {cat.name}
                    </span>
                  )}
                  <h3 class="font-sans font-semibold text-[13px] text-ink leading-snug line-clamp-2 group-hover:text-navy transition-colors mb-1.5">
                    {post.title}
                  </h3>
                  <div class="text-[11px] text-muted font-sans">
                    {formatDate(post.published_date)}{post.reading_time ? ` · ${post.reading_time} min` : ""}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
        <div class="px-5 py-4 border-t border-border flex-shrink-0">
          <a href="/blog" class="text-gold text-sm font-sans font-medium hover:text-navy transition-colors flex items-center gap-1">
            Ver todas as notícias <span>›</span>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Destaques do Dia -->
  {highlights.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 pb-14">
      <div class="flex items-end justify-between mb-6">
        <h2 class="font-display font-bold text-2xl text-ink">Destaques do Dia</h2>
        <a href="/blog" class="text-gold text-sm font-sans font-medium hover:text-navy transition-colors flex items-center gap-1">
          Ver todos os destaques <span>›</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {highlights.map((post) => {
          const cat = post.category;
          const imgSrc = assetUrl(post.image, directusUrl, "width=700&height=450&fit=cover&quality=80");
          return (
            <a href={`/blog/${post.slug}`} class="group block bg-white rounded-xl overflow-hidden border border-border shadow-sm hover:shadow-md transition-all no-underline">
              <div class="overflow-hidden h-48">
                {imgSrc ? (
                  <img src={imgSrc} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                ) : (
                  <CoverImage
                    title={post.title}
                    slug={post.slug}
                    categoryName={cat?.name}
                    categoryColor={cat?.color ?? "#0f2340"}
                    icon={categoryIcon(cat?.slug ?? "")}
                    showTitle={true}
                    class="w-full h-full group-hover:scale-105 transition-transform duration-300"
                  />
                )}
              </div>
              <div class="p-5">
                {cat && (
                  <span
                    class="inline-block text-[10px] font-sans font-bold uppercase tracking-wider px-2.5 py-1 rounded-full mb-3"
                    style={`background: ${cat.color ?? "#0f2340"}1a; color: ${cat.color ?? "#0f2340"}`}
                  >
                    {cat.name}
                  </span>
                )}
                <h3 class="font-display font-bold text-[17px] text-ink leading-snug line-clamp-2 mb-2 group-hover:text-navy transition-colors">
                  {post.title}
                </h3>
                {post.excerpt && (
                  <p class="text-muted text-sm leading-relaxed line-clamp-2 mb-4">{post.excerpt}</p>
                )}
                <div class="text-xs text-muted/70 font-sans border-t border-border pt-3">
                  {formatDate(post.published_date)}{post.reading_time ? ` · ${post.reading_time} min de leitura` : ""}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Explore por Área -->
  {categories.length > 0 && (
    <section class="bg-white border-y border-border py-12">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-8">
          <h2 class="font-display font-bold text-2xl text-ink">Explore por Área</h2>
          <p class="text-muted font-sans text-sm mt-1.5">Navegue pelas principais categorias do portal</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
          {categories.map((cat) => {
            return (
              <a
                href={`/categoria/${cat.slug}`}
                class="flex flex-col items-center gap-2.5 p-4 rounded-xl border border-border bg-paper hover:bg-white hover:shadow-sm transition-all no-underline text-center group"
              >
                <span
                  class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform overflow-hidden p-1.5"
                  style={`background: ${cat.color ?? "#0f2340"}`}
                >
                  <img
                    src={getAreaIcon(cat.slug)}
                    alt={cat.name}
                    class="w-full h-full object-contain"
                    loading="lazy"
                  />
                </span>
                <div>
                  <span class="text-xs font-sans font-semibold text-ink leading-snug block">{cat.name}</span>
                  {cat.description && (
                    <span class="text-[11px] font-sans text-muted mt-0.5 block line-clamp-1">{cat.description}</span>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Conheça nossos cursos -->
  <section class="relative overflow-hidden">

    <!-- Topo navy: cabeçalho + chips -->
    <div class="bg-[#0f2340] relative overflow-hidden pt-16 pb-32">

      <!-- Monograma "GJ" decorativo -->
      <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none select-none leading-none font-display font-bold text-white/[0.04] text-[22rem] tracking-tighter pr-4 hidden lg:block">GJ</div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">

        <!-- Label + título -->
        <div class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 bg-gold flex-shrink-0"></div>
            <span class="text-gold text-[10px] font-sans font-bold uppercase tracking-[0.2em]">Preparatórios Golden Jus</span>
          </div>
          <h2 class="font-display font-bold text-white text-3xl md:text-4xl leading-tight max-w-xl mb-4">
            Conheça nossos <span class="text-gold">cursos</span>
          </h2>
          <p class="text-white/55 font-serif text-base leading-relaxed max-w-2xl">
            Preparação de profundidade para as principais carreiras jurídicas de alto nível. Para quem já entendeu que concursos de elite não se vencem com superficialidade.
          </p>
        </div>

        <!-- Chips de diferenciais -->
        <div class="flex flex-wrap gap-3">
          <!-- Profundidade de conteúdo -->
          <div class="flex items-center gap-2 bg-white/[0.07] border border-white/10 rounded-full px-4 py-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c8960c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <span class="text-white/80 text-xs font-sans font-medium">Profundidade de Conteúdo</span>
          </div>
          <!-- Professores experientes -->
          <div class="flex items-center gap-2 bg-white/[0.07] border border-white/10 rounded-full px-4 py-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c8960c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="text-white/80 text-xs font-sans font-medium">Professores Experientes</span>
          </div>
          <!-- Todas as fases -->
          <div class="flex items-center gap-2 bg-white/[0.07] border border-white/10 rounded-full px-4 py-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c8960c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            <span class="text-white/80 text-xs font-sans font-medium">Objetiva até a Oral</span>
          </div>
          <!-- Materiais premium -->
          <div class="flex items-center gap-2 bg-white/[0.07] border border-white/10 rounded-full px-4 py-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c8960c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
            <span class="text-white/80 text-xs font-sans font-medium">Materiais Premium</span>
          </div>
          <!-- Ambiente de alto nível -->
          <div class="flex items-center gap-2 bg-white/[0.07] border border-white/10 rounded-full px-4 py-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c8960c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="text-white/80 text-xs font-sans font-medium">Ambiente de Alto Nível</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Cards: sobrepostos na transição navy → paper -->
    <div class="bg-paper pt-0 pb-16">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-5 -mt-24 relative z-10">

          <!-- Juiz Federal -->
          <a href="/cursos/juiz-federal" class="group bg-white rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 no-underline flex flex-col">
            <div class="h-1.5 bg-[#1d4ed8]"></div>
            <div class="p-6 flex flex-col flex-1">
              <div class="w-14 h-14 rounded-full bg-[#1d4ed8]/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform overflow-hidden p-1.5">
                <img src={cargo1.src} alt="Juiz Federal" class="w-full h-full object-contain" loading="lazy" />
              </div>
              <div class="h-px w-8 bg-gold mb-3"></div>
              <h3 class="font-display font-bold text-ink text-[17px] leading-snug mb-2">Juiz Federal</h3>
              <p class="text-muted text-xs font-sans leading-relaxed flex-1 mb-4">Preparação de profundidade para a Justiça Federal, com domínio real de Constitucional, Administrativo e todas as fases do concurso.</p>
              <div class="flex flex-wrap gap-1.5 mb-5">
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-[#1d4ed8]/10 text-[#1d4ed8]">TRF</span>
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-[#1d4ed8]/10 text-[#1d4ed8]">Federal</span>
              </div>
              <div class="mt-auto text-center py-2.5 rounded-lg border border-[#1d4ed8]/30 text-[#1d4ed8] text-xs font-sans font-semibold group-hover:bg-[#1d4ed8] group-hover:text-white transition-colors">
                Saiba mais
              </div>
            </div>
          </a>

          <!-- Juiz Estadual -->
          <a href="/cursos/juiz-estadual" class="group bg-white rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 no-underline flex flex-col">
            <div class="h-1.5 bg-[#15803d]"></div>
            <div class="p-6 flex flex-col flex-1">
              <div class="w-14 h-14 rounded-full bg-[#15803d]/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform overflow-hidden p-1.5">
                <img src={cargo2.src} alt="Juiz Estadual" class="w-full h-full object-contain" loading="lazy" />
              </div>
              <div class="h-px w-8 bg-gold mb-3"></div>
              <h3 class="font-display font-bold text-ink text-[17px] leading-snug mb-2">Juiz Estadual</h3>
              <p class="text-muted text-xs font-sans leading-relaxed flex-1 mb-4">Formação de alto nível para magistratura estadual, com professores experientes e preparação estruturada da objetiva à oral.</p>
              <div class="flex flex-wrap gap-1.5 mb-5">
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-[#15803d]/10 text-[#15803d]">TJ</span>
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-[#15803d]/10 text-[#15803d]">Estadual</span>
              </div>
              <div class="mt-auto text-center py-2.5 rounded-lg border border-[#15803d]/30 text-[#15803d] text-xs font-sans font-semibold group-hover:bg-[#15803d] group-hover:text-white transition-colors">
                Saiba mais
              </div>
            </div>
          </a>

          <!-- Promotor de Justiça -->
          <a href="/cursos/promotor-de-justica" class="group bg-white rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 no-underline flex flex-col">
            <div class="h-1.5 bg-[#9f1239]"></div>
            <div class="p-6 flex flex-col flex-1">
              <div class="w-14 h-14 rounded-full bg-[#9f1239]/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform overflow-hidden p-1.5">
                <img src={cargo3.src} alt="Promotor de Justiça" class="w-full h-full object-contain" loading="lazy" />
              </div>
              <div class="h-px w-8 bg-gold mb-3"></div>
              <h3 class="font-display font-bold text-ink text-[17px] leading-snug mb-2">Promotor de Justiça</h3>
              <p class="text-muted text-xs font-sans leading-relaxed flex-1 mb-4">Preparação sólida e estratégica para o Ministério Público Estadual, com profundidade em Penal, Processual e todas as fases avaliativas.</p>
              <div class="flex flex-wrap gap-1.5 mb-5">
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-[#9f1239]/10 text-[#9f1239]">MP</span>
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-[#9f1239]/10 text-[#9f1239]">Estadual</span>
              </div>
              <div class="mt-auto text-center py-2.5 rounded-lg border border-[#9f1239]/30 text-[#9f1239] text-xs font-sans font-semibold group-hover:bg-[#9f1239] group-hover:text-white transition-colors">
                Saiba mais
              </div>
            </div>
          </a>

          <!-- Procurador da República — DESTAQUE -->
          <a href="/cursos/procurador-da-republica" class="group bg-[#0f2340] rounded-2xl overflow-hidden border border-gold/40 shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 no-underline flex flex-col relative">
            <div class="absolute top-3 right-3">
              <span class="bg-gold text-white text-[9px] font-sans font-bold uppercase tracking-widest px-2 py-0.5 rounded-full">Destaque</span>
            </div>
            <div class="h-1.5 bg-gold"></div>
            <div class="p-6 flex flex-col flex-1">
              <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform overflow-hidden p-1.5">
                <img src={cargo4.src} alt="Procurador da República" class="w-full h-full object-contain" loading="lazy" />
              </div>
              <div class="h-px w-8 bg-gold mb-3"></div>
              <h3 class="font-display font-bold text-white text-[17px] leading-snug mb-2">Procurador da República</h3>
              <p class="text-white/55 text-xs font-sans leading-relaxed flex-1 mb-4">O preparatório de elite do MPF. 70% dos aprovados no último concurso foram alunos do Golden Jus. Profundidade e resultado reais.</p>
              <div class="flex flex-wrap gap-1.5 mb-5">
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-gold/20 text-gold">MPF</span>
                <span class="text-[10px] font-sans font-semibold px-2 py-0.5 rounded-full bg-gold/20 text-gold">Federal</span>
              </div>
              <div class="mt-auto text-center py-2.5 rounded-lg bg-gold text-white text-xs font-sans font-bold group-hover:bg-[#b8860b] transition-colors">
                Saiba mais
              </div>
            </div>
          </a>

          <!-- Delegado de Polícia -->
