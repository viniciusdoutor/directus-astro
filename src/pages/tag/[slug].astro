---
import Layout from "../../layouts/Layout.astro";
import directus from "../../lib/directus";
import { readItems } from "@directus/sdk";
import PostCard from "../../components/PostCard.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getTags } from "../../lib/utils";
import type { Tag } from "../../lib/directus";

export async function getStaticPaths() {
  const tags = await directus.request(
    readItems("tags", { fields: ["id", "name", "slug"] })
  );
  return tags.map(tag => ({ params: { slug: tag.slug }, props: { tag } }));
}

interface Props { tag: Tag; }
const { tag } = Astro.props;
const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL;

const [allPosts, categories, tags] = await Promise.all([
  directus.request(readItems("posts", {
    filter: { status: { _eq: "published" } },
    fields: [
      "id", "title", "slug", "excerpt", "published_date", "reading_time", "image", "featured",
      { category: ["id", "name", "slug", "color"] },
      { tags: [{ tags_id: ["id", "name", "slug"] }] },
    ] as any,
    sort: ["-published_date"],
    limit: 100,
  })),
  directus.request(readItems("categories", { fields: ["id", "name", "slug", "color", "description"], sort: ["name"] })),
  directus.request(readItems("tags", { fields: ["id", "name", "slug"], sort: ["name"] })),
]);

const posts = allPosts.filter(post => {
  const postTags = getTags((post as any).tags);
  return postTags.some(t => t.slug === tag.slug);
});
---

<Layout title={`#${tag.name} — Blog`}>

  <div class="bg-white border-b border-border" style="border-top: 4px solid #c8960c">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <p class="text-xs font-sans text-muted mb-2">
        <a href="/" class="hover:text-gold transition-colors no-underline">Início</a>
        <span class="mx-1.5">›</span>
        <a href="/blog" class="hover:text-gold transition-colors no-underline">Blog</a>
        <span class="mx-1.5">›</span>
        Tag
      </p>
      <h1 class="font-display font-bold text-4xl text-ink mb-1">#{tag.name}</h1>
      <p class="text-xs font-sans text-muted">
        {posts.length} post{posts.length !== 1 ? "s" : ""}
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10">

      <div>
        {posts.length === 0 ? (
          <div class="py-16 text-center">
            <p class="text-muted font-sans">Nenhum post com esta tag.</p>
            <a href="/blog" class="mt-4 inline-block text-sm font-sans text-gold hover:underline">
              Ver todos os posts
            </a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {posts.map(post => <PostCard post={post as any} directusUrl={directusUrl} />)}
          </div>
        )}
      </div>

      <Sidebar {categories} {tags} activeTagSlug={tag.slug} />

    </div>
  </div>

</Layout>
